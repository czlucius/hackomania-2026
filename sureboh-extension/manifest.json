{
  "manifest_version": 3,
  "name": "SureAnot.ai",
  "version": "1.0.0",
  "description": "Evaluates WhatsApp messages for credibility with contextual nutrition labels.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://web.whatsapp.com/*",
    "*://forums.hardwarezone.com.sg/*",
    "*://web.telegram.org/*",
    "*://www.instagram.com/*",
    "*://*.fbcdn.net/*",
    "*://*.cdninstagram.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "SureAnot.ai",
    "default_popup": "index.html"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "js": [
        "src/content.jsx"
      ],
      "matches": [
        "*://web.whatsapp.com/*",
        "*://forums.hardwarezone.com.sg/*",
        "*://web.telegram.org/*",
        "*://www.reddit.com/*",
        "*://www.instagram.com/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.js",
        "assets/*.css",
        "assets/*.png",
        "assets/*.jpg",
        "assets/*.svg"
      ],
      "matches": [
        "*://web.whatsapp.com/*",
        "*://forums.hardwarezone.com.sg/*",
        "*://web.telegram.org/*",
        "*://www.reddit.com/*",
        "*://www.instagram.com/*"
      ]
    }
  ]
}