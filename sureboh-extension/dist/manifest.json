{
  "manifest_version": 3,
  "name": "SureBoh.ai",
  "version": "1.0.0",
  "description": "Evaluates WhatsApp messages for credibility with contextual nutrition labels.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://web.whatsapp.com/*",
    "*://forums.hardwarezone.com.sg/*",
    "*://web.telegram.org/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.jsx-loader-BxVN1_np.js"
      ],
      "matches": [
        "*://web.whatsapp.com/*",
        "*://forums.hardwarezone.com.sg/*",
        "*://web.telegram.org/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://forums.hardwarezone.com.sg/*",
        "*://web.telegram.org/*",
        "*://web.whatsapp.com/*"
      ],
      "resources": [
        "assets/zap-BHQr4dbS.js",
        "assets/content.jsx-BOKoXZNb.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
